# CWT Predictions Market — Environment Variables
# Copy this file to .env and fill in your API keys.

# ── OpenRouter (LLM Provider — required) ────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model (free tier)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Apify (Web Scraping — optional, for RAG enrichment) ──
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here

# ── RAG Mode ────────────────────────────────────────
# "simple" = JSON keyword search (default, no extra deps)
# "advanced" = ChromaDB vector store (requires: pip install chromadb sentence-transformers)
RAG_MODE=simple
